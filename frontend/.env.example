# Base URL de la API del user-service
# En desarrollo, el proxy de Vite redirige /api → http://localhost:8081
# Si quieres apuntar directamente al backend sin proxy, usa:
# VITE_API_BASE_URL=http://localhost:8081
VITE_API_BASE_URL=/api

# OAuth Client ID de Google (Web application)
VITE_GOOGLE_CLIENT_ID=

