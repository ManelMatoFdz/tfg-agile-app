USER_SERVICE_PORT=8081
PROJECT_SERVICE_PORT=8082

USER_DB_HOST=localhost
USER_DB_PORT=5433
USER_DB_USER=user
USER_DB_PASS=user
USER_DB_NAME=userdb

PROJECT_DB_HOST=localhost
PROJECT_DB_PORT=5434
PROJECT_DB_USER=project
PROJECT_DB_PASS=project
PROJECT_DB_NAME=projectdb

JWT_SECRET=replace-with-a-long-random-secret-min-32-bytes
JWT_EXPIRATION_MINUTES=60
JWT_ISSUER=agileflow-user-service
JWT_AUDIENCE=agileflow-api
REFRESH_TOKEN_EXPIRATION_DAYS=7

RESET_PASSWORD_EXPIRATION_MINUTES=15
RESET_PASSWORD_BASE_URL=http://localhost:3000/reset-password

MAIL_ENABLED=false
MAIL_FROM=no-reply@agileflow.local
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_AUTH=true
SMTP_STARTTLS=true

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/
NOTIFICATIONS_QUEUE_ENABLED=false
NOTIFICATIONS_QUEUE_NAME=user-service.notifications
NOTIFICATIONS_EXCHANGE=agileflow.notifications
NOTIFICATIONS_ROUTING_KEY=user-service.notification
INTERNAL_API_KEY=dev-internal-key

AVATAR_PUBLIC_BASE_URL=http://localhost:8081/assets/avatars

GOOGLE_CLIENT_ID=
GOOGLE_TOKEN_INFO_URL=https://oauth2.googleapis.com/tokeninfo
